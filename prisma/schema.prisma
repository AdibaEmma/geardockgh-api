generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────

enum CustomerRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PreorderStatus {
  RESERVED
  DEPOSIT_PAID
  FULLY_PAID
  READY_TO_SHIP
  FULFILLED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  MOMO
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ShippingMethod {
  AIR
  SEA
}

enum LeadSource {
  NEWSLETTER
  REGISTRATION
  WHATSAPP_INQUIRY
  STOCK_NOTIFICATION
  CART_ACTIVITY
  WISHLIST
  DIRECT_VISIT
  REFERRAL
}

enum LeadStatus {
  NEW
  ENGAGED
  QUALIFIED
  CONVERTED
  INACTIVE
}

// ─── TENANT ─────────────────────────────────────────────────────

model Tenant {
  id        String  @id
  name      String
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

// ─── CUSTOMER ───────────────────────────────────────────────────

model Customer {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  role        CustomerRole @default(CUSTOMER)
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  email        String
  passwordHash String       @map("password_hash")
  phone        String?
  momoNumber   String?      @map("momo_number")
  isActive    Boolean      @default(true) @map("is_active")

  orders             Order[]
  preorders          Preorder[]
  addresses          Address[]
  refreshTokens      RefreshToken[]
  stockNotifications StockNotification[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@map("customers")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime @map("expires_at")
  isRevoked  Boolean  @default(false) @map("is_revoked")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── ADDRESS ────────────────────────────────────────────────────

model Address {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?
  street     String
  city       String
  region     String
  isDefault  Boolean  @default(false) @map("is_default")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@map("addresses")
}

// ─── PRODUCT ────────────────────────────────────────────────────

model Product {
  id                   String  @id @default(uuid())
  tenantId             String  @map("tenant_id")
  importbrainProductId String? @map("importbrain_product_id")
  name                 String
  slug                 String
  description          String?
  pricePesewas         Int     @map("price_pesewas")
  comparePricePesewas  Int?    @map("compare_price_pesewas")
  costPricePesewas     Int?    @map("cost_price_pesewas")
  stockCount           Int     @default(0) @map("stock_count")
  isPreorder           Boolean @default(false) @map("is_preorder")
  isPublished          Boolean @default(false) @map("is_published")
  isFeatured           Boolean @default(false) @map("is_featured")
  isFlashDeal          Boolean @default(false) @map("is_flash_deal")
  allowPreorderWhenOOS Boolean @default(false) @map("allow_preorder_when_oos")
  estArrivalDate        DateTime? @map("est_arrival_date")
  preorderDepositType   String?   @map("preorder_deposit_type")
  preorderDepositValue  Int?      @map("preorder_deposit_value")
  preorderMinUnits      Int?      @map("preorder_min_units")
  preorderSlotsTaken    Int             @default(0) @map("preorder_slots_taken")
  preorderSlotTarget    Int?            @map("preorder_slot_target")
  shippingMethod        ShippingMethod? @map("shipping_method")
  category              String?
  subcategory           String?
  imagesJson           String? @map("images_json") @db.Text
  specsJson            String? @map("specs_json") @db.Text
  optionsJson          String? @map("options_json") @db.Text

  variants           ProductVariant[]
  orderItems         OrderItem[]
  preorders          Preorder[]
  auditLogs          ProductAuditLog[]
  stockNotifications StockNotification[]
  bundleItems        BundleItem[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([category])
  @@index([category, subcategory])
  @@index([isPublished])
  @@map("products")
}

model ProductVariant {
  id           String @id @default(uuid())
  productId    String @map("product_id")
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name         String
  pricePesewas Int    @map("price_pesewas")
  stockCount   Int    @default(0) @map("stock_count")

  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("product_variants")
}

// ─── ORDER ──────────────────────────────────────────────────────

model Order {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  orderNumber      String      @map("order_number")
  customerId       String      @map("customer_id")
  customer         Customer    @relation(fields: [customerId], references: [id])
  status           OrderStatus @default(PENDING_PAYMENT)
  totalPesewas     Int         @map("total_pesewas")
  subtotalPesewas  Int         @map("subtotal_pesewas")
  deliveryFee      Int         @default(0) @map("delivery_fee")
  discountPesewas  Int         @default(0) @map("discount_pesewas")
  shippingAddressId String?    @map("shipping_address_id")
  shippingAddress  Address?    @relation(fields: [shippingAddressId], references: [id])
  notes            String?

  items    OrderItem[]
  payments Payment[]
  shipment Shipment?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([orderNumber, tenantId])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String          @map("order_id")
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String          @map("product_id")
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?         @map("variant_id")
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  quantity             Int
  unitPricePesewas     Int     @map("unit_price_pesewas")
  selectedOptionsJson  String? @map("selected_options_json") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── PREORDER ───────────────────────────────────────────────────

model Preorder {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  customerId      String         @map("customer_id")
  customer        Customer       @relation(fields: [customerId], references: [id])
  productId       String         @map("product_id")
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int
  depositPesewas  Int            @map("deposit_pesewas")
  totalPesewas             Int            @map("total_pesewas")
  balancePesewas           Int            @map("balance_pesewas")
  paystackBalanceReference String?        @map("paystack_balance_reference")
  estArrivalDate           DateTime?      @map("est_arrival_date")
  selectedOptionsJson  String?        @map("selected_options_json") @db.Text
  status          PreorderStatus @default(RESERVED)
  notes           String?

  payments Payment[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@map("preorders")
}

// ─── PAYMENT ────────────────────────────────────────────────────

model Payment {
  id             String          @id @default(uuid())
  orderId        String?         @map("order_id")
  order          Order?          @relation(fields: [orderId], references: [id])
  preorderId     String?         @map("preorder_id")
  preorder       Preorder?       @relation(fields: [preorderId], references: [id])
  provider       PaymentProvider
  transactionId  String?         @map("transaction_id")
  reference      String?         @unique
  amountPesewas  Int             @map("amount_pesewas")
  status         PaymentStatus   @default(PENDING)
  metadata       String?         @db.Text
  paidAt         DateTime?       @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([preorderId])
  @@index([transactionId])
  @@index([reference])
  @@map("payments")
}

// ─── SHIPMENT ───────────────────────────────────────────────────

model Shipment {
  id              String    @id @default(uuid())
  orderId         String    @unique @map("order_id")
  order           Order     @relation(fields: [orderId], references: [id])
  carrier         String?
  trackingNumber  String?   @map("tracking_number")
  dispatchedAt    DateTime? @map("dispatched_at")
  deliveredAt     DateTime? @map("delivered_at")
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("shipments")
}

// ─── IMPORTBRAIN CONNECTION ─────────────────────────────────────

model ImportBrainConnection {
  id                  String    @id @default(uuid())
  tenantId            String    @unique @map("tenant_id")
  importbrainTenantId String    @map("importbrain_tenant_id")
  integrationId       String    @map("integration_id")
  apiKey              String    @map("api_key")
  apiUrl              String    @map("api_url")
  platformKey         String?   @map("platform_key")
  callbackKey         String?   @map("callback_key")
  status              String    @default("active")
  connectedAt         DateTime  @default(now()) @map("connected_at")
  disconnectedAt      DateTime? @map("disconnected_at")

  @@map("importbrain_connections")
}

// ─── EVENT LOG ──────────────────────────────────────────────────

model EventLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  event     String
  direction String   // 'inbound' | 'outbound'
  payload   String   @db.Text
  status    String   @default("pending") // 'pending' | 'processed' | 'failed'
  error     String?  @db.Text
  processedAt DateTime? @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
  @@map("event_logs")
}

// ─── NOTIFICATION LOG ───────────────────────────────────────────

model NotificationLog {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  preorderId   String?   @map("preorder_id")
  orderId      String?   @map("order_id")
  customerId   String    @map("customer_id")
  channel      String    // 'whatsapp' | 'sms' | 'email'
  templateName String    @map("template_name")
  recipient    String
  payload      String?   @db.Text
  status       String    @default("pending") // 'pending' | 'sent' | 'failed'
  error        String?   @db.Text
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([customerId])
  @@index([preorderId])
  @@index([status])
  @@map("notification_logs")
}

// ─── PRODUCT AUDIT LOG ─────────────────────────────────────────

model ProductAuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  productId String   @map("product_id")
  action    String   // 'created' | 'updated' | 'deleted' | 'published' | 'unpublished'
  changes   String?  @db.Text // JSON array of { field, from, to }
  userId    String?  @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("product_audit_logs")
}

// ─── BUNDLE ──────────────────────────────────────────────────

model Bundle {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  name              String
  slug              String
  tagline           String?
  description       String?
  pricePesewas      Int      @map("price_pesewas")
  comparePricePesewas Int?   @map("compare_price_pesewas")
  isPublished       Boolean  @default(false) @map("is_published")
  isFeatured        Boolean  @default(false) @map("is_featured")
  isPreorder        Boolean  @default(false) @map("is_preorder")
  stockCount        Int      @default(0) @map("stock_count")
  imageUrl          String?  @map("image_url")
  category          String?

  items BundleItem[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([isPublished])
  @@index([isFeatured])
  @@map("bundles")
}

model BundleItem {
  id           String  @id @default(uuid())
  bundleId     String  @map("bundle_id")
  bundle       Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId    String  @map("product_id")
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int     @default(1)
  isBonus      Boolean @default(false) @map("is_bonus")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([bundleId])
  @@index([productId])
  @@map("bundle_items")
}

// ─── NEWSLETTER SUBSCRIBER ────────────────────────────────────

model NewsletterSubscriber {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  source       String    @default("website") // 'website' | 'preorder' | 'checkout'
  isActive     Boolean   @default(true) @map("is_active")
  subscribedAt DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([isActive])
  @@map("newsletter_subscribers")
}

// ─── EMAIL SEQUENCE ──────────────────────────────────────────

enum EmailSequenceStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model EmailSequence {
  id          String              @id @default(uuid())
  tenantId    String              @map("tenant_id")
  name        String
  description String?
  status      EmailSequenceStatus @default(ACTIVE)

  steps       EmailSequenceStep[]
  enrollments EmailSequenceEnrollment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("email_sequences")
}

model EmailSequenceStep {
  id         String        @id @default(uuid())
  sequenceId String        @map("sequence_id")
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepOrder  Int           @map("step_order")
  delayHours Int           @map("delay_hours")
  subject    String
  htmlBody   String        @map("html_body") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sequenceId])
  @@map("email_sequence_steps")
}

model EmailSequenceEnrollment {
  id                String        @id @default(uuid())
  sequenceId        String        @map("sequence_id")
  sequence          EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  subscriberId      String        @map("subscriber_id")
  email             String
  currentStepOrder  Int           @default(0) @map("current_step_order")
  nextSendAt        DateTime?     @map("next_send_at")
  isComplete        Boolean       @default(false) @map("is_complete")
  cancelledAt       DateTime?     @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sequenceId, email])
  @@index([nextSendAt])
  @@index([isComplete])
  @@map("email_sequence_enrollments")
}

// ─── STOCK NOTIFICATION ───────────────────────────────────────

model StockNotification {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  productId  String    @map("product_id")
  customerId String    @map("customer_id")
  notifiedAt DateTime? @map("notified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([tenantId])
  @@index([productId])
  @@map("stock_notifications")
}

// ─── LEAD TRACKING ──────────────────────────────────────────────

model Lead {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  customerId       String?     @map("customer_id")
  email            String
  source           LeadSource
  status           LeadStatus  @default(NEW)
  score            Int         @default(0)
  firstTouchAt     DateTime    @default(now()) @map("first_touch_at")
  lastActivityAt   DateTime    @default(now()) @map("last_activity_at")
  convertedAt      DateTime?   @map("converted_at")
  convertedOrderId String?     @map("converted_order_id")
  metadata         String?     @db.Text

  activities LeadActivity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([status])
  @@index([score])
  @@index([source])
  @@index([customerId])
  @@index([lastActivityAt])
  @@map("leads")
}

model LeadActivity {
  id         String  @id @default(uuid())
  leadId     String  @map("lead_id")
  lead       Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenantId   String  @map("tenant_id")
  action     String
  productId  String? @map("product_id")
  metadata   String? @db.Text
  scoreDelta Int     @default(0) @map("score_delta")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("lead_activities")
}

model LeadScoringRule {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  action   String
  points   Int
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, action])
  @@index([tenantId])
  @@map("lead_scoring_rules")
}
